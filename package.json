{
  "name": "ai-calling-system",
  "version": "1.0.0",
  "description": "Production-ready AI/IVR automated calling system for business lead generation",
  "main": "apps/backend/src/server.js",
  "scripts": {
    "start": "node apps/backend/src/server.js",
    "dev": "nodemon apps/backend/src/server.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart all",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "twilio": "^3.84.1",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "bull": "^4.11.4",
    "redis": "^4.6.10",
    "axios": "^1.5.0",
    "multer": "^1.4.5-lts.1",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5",
    "csv-parser": "^3.0.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pm2": "^5.13.14"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}